{
  "manifest_version": 3,
  "name": "DSA Reviser - Spaced Repetition for LeetCode",
  "version": "1.0",
  "description": "Never forget Data Structures & Algorithms with spaced repetition. Save LeetCode problems and revise based on your custom preference.",

  "permissions": ["storage", "activeTab", "scripting", "alarms", "notifications"],
  
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "options_page": "options.html"
}